# Application
APP_NAME=MintJobs
APP_VERSION=1.0.0
NODE_ENV=development
API_PREFIX=api
SWAGGER_ENABLED=true

# Service Ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
JOB_SERVICE_PORT=3003
ESCROW_SERVICE_PORT=3004
LAUNCHPAD_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
UPLOAD_SERVICE_PORT=3007
CHAT_SERVICE_PORT=3008

# Legacy (kept for backward compatibility)
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=mintjobs
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_MIGRATIONS_RUN=true
DB_MIGRATIONS_TABLE_NAME=typeorm_migrations
DB_MIGRATIONS_DIRECTORY=migrations

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=mintjobs.exchange
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RECONNECT_DELAY=5000
RABBITMQ_MAX_RECONNECT_ATTEMPTS=10

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Admin
ADMIN_TOKEN=your-super-secret-admin-token-change-in-production

# Privy
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# AWS S3
AWS_REGION=us-east-1
# Optional: bucket region if AWS_REGION is overridden by your shell (~/.aws, export, etc.)
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name

# Solana
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=5b476d89-5514-4f8c-8238-066c06008780
SOLANA_AUTHORITY_KEYPAIR=[183,238,201,36,24,56,215,111,92,40,12,31,0,104,11,224,125,46,51,130,251,189,187,217,21,204,245,212,156,51,99,244,232,80,151,20,71,0,89,131,242,1,62,223,37,223,69,158,233,24,168,203,10,114,215,25,79,226,67,123,75,67,105,193]
SOLANA_PROGRAM_ID=DSpvnGTUxHo47tLgGJygq9F1ZX1TvGVrv7Ku2jAfBew8

# Proposal limits
DAILY_PROPOSAL_LIMIT=5

# Pinata / IPFS
PINATA_JWT=your-pinata-jwt-token
PINATA_GATEWAY=https://gateway.pinata.cloud
